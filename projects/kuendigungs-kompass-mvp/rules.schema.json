{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kündigungs-Kompass Rules Schema V2",
  "description": "Regelstruktur für den operativen MVP mit expliziter Trennung zwischen belastbaren Aussagen, vorsichtigen Prüfhinweisen und vorerst nicht zu verwendenden Aussagen.",
  "type": "object",
  "required": [
    "rulesVersion",
    "rules"
  ],
  "properties": {
    "rulesVersion": {
      "type": "string",
      "const": "v2"
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rule"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "condition": {
      "type": "object",
      "required": [
        "field",
        "operator",
        "value"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "operator": {
          "type": "string",
          "enum": [
            "equals",
            "notEquals",
            "includes",
            "notIncludes",
            "exists",
            "ltDaysToDate",
            "lteDaysToDate",
            "gtDaysToDate"
          ]
        },
        "value": {}
      },
      "additionalProperties": false
    },
    "effect": {
      "type": "object",
      "required": [
        "type",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "immediateAction",
            "deadlineAlert",
            "riskFlag",
            "warning",
            "opportunityFlag",
            "documentPrompt",
            "advisorQuestion",
            "disclaimer",
            "manualReview"
          ]
        },
        "payload": {
          "type": "object",
          "required": [
            "id",
            "label",
            "statementClass"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "why": {
              "type": "string"
            },
            "priority": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10
            },
            "timing": {
              "type": "string"
            },
            "statementClass": {
              "type": "string",
              "enum": [
                "mvp-reliable",
                "cautious-check",
                "do-not-use-yet"
              ]
            },
            "evidenceSource": {
              "type": "string",
              "enum": [
                "official",
                "statute",
                "mixed",
                "internal-policy"
              ]
            },
            "audienceNote": {
              "type": "string"
            },
            "escalateIf": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": [
        "id",
        "stage",
        "conditions",
        "effects",
        "severity",
        "outcomeType",
        "ruleClass",
        "tags"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "stage": {
          "type": "string",
          "enum": [
            "triage",
            "deadline",
            "contract",
            "risk",
            "synthesis"
          ]
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          },
          "minItems": 1
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          },
          "minItems": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        "outcomeType": {
          "type": "string",
          "enum": [
            "deadline-protection",
            "alg1-risk",
            "contract-risk",
            "special-protection",
            "preparation",
            "opportunity"
          ]
        },
        "ruleClass": {
          "type": "string",
          "enum": [
            "mvp-reliable",
            "cautious-check",
            "do-not-use-yet"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "example": {
    "rulesVersion": "v2",
    "rules": [
      {
        "id": "jobseeker-registration-missing",
        "stage": "deadline",
        "conditions": [
          {
            "field": "jobseeker_registered",
            "operator": "equals",
            "value": false
          }
        ],
        "effects": [
          {
            "type": "deadlineAlert",
            "payload": {
              "id": "jobseeker-registration-deadline",
              "label": "Arbeitsuchendmeldung sofort prüfen oder nachholen",
              "description": "Die Arbeitsuchendmeldung soll in der Regel spätestens 3 Monate vor Ende des Arbeitsverhältnisses erfolgen; erfährst du später davon, binnen 3 Tagen.",
              "timing": "sofort",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          },
          {
            "type": "immediateAction",
            "payload": {
              "id": "complete-jobseeker-registration",
              "label": "Meldung direkt online, telefonisch oder mit Termin anstoßen",
              "why": "Zu späte Meldungen können finanzielle Nachteile beim späteren Arbeitslosengeld auslösen.",
              "priority": 1,
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "critical",
        "outcomeType": "deadline-protection",
        "ruleClass": "mvp-reliable",
        "tags": [
          "agentur",
          "frist",
          "alg1"
        ]
      },
      {
        "id": "unemployment-registration-missing",
        "stage": "deadline",
        "conditions": [
          {
            "field": "already_unemployed_now",
            "operator": "equals",
            "value": true
          },
          {
            "field": "unemployment_registered",
            "operator": "equals",
            "value": false
          }
        ],
        "effects": [
          {
            "type": "deadlineAlert",
            "payload": {
              "id": "unemployment-registration-deadline",
              "label": "Arbeitslosmeldung sofort prüfen oder nachholen",
              "description": "Die Arbeitslosmeldung ist eine eigene Pflicht und soll spätestens am ersten Tag der Arbeitslosigkeit erfolgt sein. Wenn das noch offen ist, jetzt direkt handeln.",
              "timing": "sofort",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          },
          {
            "type": "immediateAction",
            "payload": {
              "id": "complete-unemployment-registration",
              "label": "Arbeitslosmeldung als separaten Schritt direkt anstoßen",
              "why": "Arbeitsuchendmeldung und Arbeitslosmeldung sind nicht dasselbe. Für Leistungsbezug und Start der Arbeitslosigkeit muss die separate Meldung geprüft werden.",
              "priority": 1,
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "critical",
        "outcomeType": "deadline-protection",
        "ruleClass": "mvp-reliable",
        "tags": [
          "agentur",
          "arbeitslosmeldung",
          "frist",
          "alg1"
        ]
      },
      {
        "id": "jobseeker-vs-unemployment-registration",
        "stage": "synthesis",
        "conditions": [
          {
            "field": "jobseeker_registered",
            "operator": "exists",
            "value": true
          }
        ],
        "effects": [
          {
            "type": "disclaimer",
            "payload": {
              "id": "agency-registration-distinction",
              "label": "Arbeitsuchendmeldung ersetzt nicht Arbeitslosmeldung",
              "description": "Beide Meldungen sind fachlich getrennt. Im MVP soll diese Unterscheidung explizit sichtbar bleiben.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "medium",
        "outcomeType": "deadline-protection",
        "ruleClass": "mvp-reliable",
        "tags": [
          "agentur",
          "arbeitsuchendmeldung",
          "arbeitslosmeldung"
        ]
      },
      {
        "id": "termination-lawsuit-window",
        "stage": "deadline",
        "conditions": [
          {
            "field": "termination_access_date",
            "operator": "exists",
            "value": true
          }
        ],
        "effects": [
          {
            "type": "deadlineAlert",
            "payload": {
              "id": "three-week-lawsuit-window",
              "label": "3-Wochen-Frist für Kündigungsschutzklage prüfen",
              "description": "Wer die Unwirksamkeit einer schriftlichen Kündigung geltend machen will, muss regelmäßig innerhalb von 3 Wochen nach Zugang Klage erheben.",
              "timing": "sehr kurzfristig",
              "statementClass": "mvp-reliable",
              "evidenceSource": "statute"
            }
          },
          {
            "type": "disclaimer",
            "payload": {
              "id": "no-validity-assessment",
              "label": "Keine Wirksamkeitsprüfung im Tool",
              "description": "Ob die Kündigung im Einzelfall wirksam oder angreifbar ist, leistet der MVP nicht.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "internal-policy"
            }
          }
        ],
        "severity": "critical",
        "outcomeType": "deadline-protection",
        "ruleClass": "mvp-reliable",
        "tags": [
          "kuendigung",
          "arbeitsgericht",
          "frist"
        ]
      },
      {
        "id": "agreement-not-signed-yet",
        "stage": "contract",
        "conditions": [
          {
            "field": "agreement_present",
            "operator": "equals",
            "value": true
          },
          {
            "field": "agreement_already_signed",
            "operator": "equals",
            "value": false
          }
        ],
        "effects": [
          {
            "type": "warning",
            "payload": {
              "id": "do-not-sign-immediately",
              "label": "Nicht vorschnell unterschreiben",
              "description": "Aufhebungs- oder Abwicklungsverträge können erhebliche Folgen für Arbeitslosengeld und Verhandlungsspielraum haben.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          },
          {
            "type": "riskFlag",
            "payload": {
              "id": "alg1-block-risk",
              "label": "Sperrzeit-/Ruhensrisiko prüfen",
              "description": "Bei Vertragsbeendigungen mit eigener Mitwirkung können Auswirkungen auf das Arbeitslosengeld entstehen.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "critical",
        "outcomeType": "alg1-risk",
        "ruleClass": "mvp-reliable",
        "tags": [
          "aufhebungsvertrag",
          "abwicklungsvertrag",
          "alg1"
        ]
      },
      {
        "id": "agreement-already-signed",
        "stage": "risk",
        "conditions": [
          {
            "field": "agreement_already_signed",
            "operator": "equals",
            "value": true
          }
        ],
        "effects": [
          {
            "type": "manualReview",
            "payload": {
              "id": "signed-agreement-review",
              "label": "Vertrag ist bereits unterschrieben: Fall nicht mehr nur als Standardfall behandeln",
              "description": "Jetzt stehen Folgenanalyse, Fristen und individuelle Beratung stärker im Vordergrund als ein allgemeiner Nicht-unterschreiben-Hinweis.",
              "statementClass": "cautious-check",
              "evidenceSource": "mixed",
              "escalateIf": "Unterschrift ist erfolgt, aber Folgen oder Anfechtbarkeit sind unklar"
            }
          }
        ],
        "severity": "high",
        "outcomeType": "contract-risk",
        "ruleClass": "cautious-check",
        "tags": [
          "signed",
          "beratung"
        ]
      },
      {
        "id": "release-does-not-end-duties",
        "stage": "risk",
        "conditions": [
          {
            "field": "release_status",
            "operator": "notEquals",
            "value": "no"
          }
        ],
        "effects": [
          {
            "type": "warning",
            "payload": {
              "id": "release-is-not-everything",
              "label": "Freistellung beendet nicht automatisch alle To-dos",
              "description": "Auch bei Freistellung bleiben Meldungen, Fristen und Unterlagenthemen relevant.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "medium",
        "outcomeType": "preparation",
        "ruleClass": "mvp-reliable",
        "tags": [
          "freistellung",
          "organisation"
        ]
      },
      {
        "id": "special-protection-indicator",
        "stage": "risk",
        "conditions": [
          {
            "field": "special_protection_indicator",
            "operator": "notIncludes",
            "value": "none_known"
          }
        ],
        "effects": [
          {
            "type": "riskFlag",
            "payload": {
              "id": "special-protection-red-flag",
              "label": "Möglicher Sonderkündigungsschutz / heikler Sonderfall",
              "description": "Hier sollte der MVP nicht normalisieren, sondern auf erhöhte Vorsicht und individuelle Prüfung umschalten.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "official"
            }
          },
          {
            "type": "manualReview",
            "payload": {
              "id": "special-protection-check",
              "label": "Sonderfall gesondert prüfen lassen",
              "description": "Ob tatsächlich ein besonderer Schutz greift, muss im Einzelfall verifiziert werden.",
              "statementClass": "cautious-check",
              "evidenceSource": "mixed"
            }
          }
        ],
        "severity": "high",
        "outcomeType": "special-protection",
        "ruleClass": "cautious-check",
        "tags": [
          "sonderfall",
          "schutz",
          "red-flag"
        ]
      },
      {
        "id": "documents-missing",
        "stage": "triage",
        "conditions": [
          {
            "field": "documents_secured",
            "operator": "includes",
            "value": "none_yet"
          }
        ],
        "effects": [
          {
            "type": "documentPrompt",
            "payload": {
              "id": "secure-core-documents",
              "label": "Kernunterlagen sofort bündeln",
              "description": "Mindestens Kündigung / Vertrag / Entwurf / Lohnunterlagen sichern, damit Beratung und Behördenwege sauber vorbereitet sind.",
              "statementClass": "mvp-reliable",
              "evidenceSource": "internal-policy"
            }
          }
        ],
        "severity": "medium",
        "outcomeType": "preparation",
        "ruleClass": "mvp-reliable",
        "tags": [
          "dokumente",
          "vorbereitung"
        ]
      },
      {
        "id": "training-opportunity",
        "stage": "synthesis",
        "conditions": [
          {
            "field": "primary_goal",
            "operator": "equals",
            "value": "plan_next_step"
          }
        ],
        "effects": [
          {
            "type": "opportunityFlag",
            "payload": {
              "id": "training-opportunity-check",
              "label": "Weiterbildung nur als Anschlusschance, nicht als Kernversprechen",
              "description": "Ein Bildungsgutschein setzt individuelle Voraussetzungen und Beratung voraus. Für den MVP nur als Option nachrangig markieren.",
              "statementClass": "cautious-check",
              "evidenceSource": "official"
            }
          }
        ],
        "severity": "low",
        "outcomeType": "opportunity",
        "ruleClass": "cautious-check",
        "tags": [
          "weiterbildung",
          "bildungsgutschein"
        ]
      },
      {
        "id": "do-not-use-compensation-promise",
        "stage": "synthesis",
        "conditions": [
          {
            "field": "agreement_present",
            "operator": "exists",
            "value": true
          }
        ],
        "effects": [
          {
            "type": "disclaimer",
            "payload": {
              "id": "no-compensation-promise",
              "label": "Keine Abfindungswahrscheinlichkeiten oder Rechenversprechen ausgeben",
              "description": "Der MVP soll keine belastbare Erwartung zu Abfindungshöhe oder Durchsetzbarkeit suggerieren.",
              "statementClass": "do-not-use-yet",
              "evidenceSource": "internal-policy"
            }
          }
        ],
        "severity": "low",
        "outcomeType": "contract-risk",
        "ruleClass": "do-not-use-yet",
        "tags": [
          "abfindung",
          "scope-guard"
        ]
      }
    ]
  }
}
